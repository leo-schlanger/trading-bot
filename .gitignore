# =============================================================================
# .gitignore - Trading Bot
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# Data & Models (download locally, don't commit)
# -----------------------------------------------------------------------------
data/
models/
*.pkl
*.parquet
*.h5

# -----------------------------------------------------------------------------
# Logs & State (runtime files)
# -----------------------------------------------------------------------------
logs/
state/
*.log

# -----------------------------------------------------------------------------
# Results (personal backtest data)
# -----------------------------------------------------------------------------
results/

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
*.pem
*.key
secrets/

# Keep only the example
!config/.env.example

# -----------------------------------------------------------------------------
# Private Documentation (deployment, costs, planning)
# -----------------------------------------------------------------------------
# Deploy guides with costs/services info
deploy/oracle/
deploy/cloudflare/SETUP_CLOUDFLARE.md
deploy/github-actions/SETUP_GITHUB_ACTIONS.md
deploy/selfhosted/SETUP_SELFHOSTED.md
deploy/telegram/SETUP_TELEGRAM.md
DEPLOY_GUIDE.md

# Planning & study documents
docs/ESTUDO_*.md
docs/planning/
docs/private/

# -----------------------------------------------------------------------------
# IDE & OS
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.wrangler/
