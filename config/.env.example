# =============================================================================
# Trading Bot Configuration
# Copy to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Trading Mode
# -----------------------------------------------------------------------------
TRADING_MODE=paper  # paper, live, backtest

# -----------------------------------------------------------------------------
# Telegram Notifications (optional)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=true

# -----------------------------------------------------------------------------
# Exchange API (required for live trading)
# -----------------------------------------------------------------------------
EXCHANGE_API_KEY=
EXCHANGE_SECRET=

# -----------------------------------------------------------------------------
# Solana/Drift (if using Drift Protocol)
# -----------------------------------------------------------------------------
# RPC_URL=https://api.mainnet-beta.solana.com
# PRIVATE_KEY=your_private_key_here
# ENVIRONMENT=devnet

# -----------------------------------------------------------------------------
# Cloudflare Storage (optional - for distributed mode)
# -----------------------------------------------------------------------------
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# CF_KV_NAMESPACE_ID=
# CF_D1_DATABASE_ID=
# CF_R2_ACCESS_KEY=
# CF_R2_SECRET_KEY=
# CF_R2_BUCKET=trading-bot

# -----------------------------------------------------------------------------
# Local Storage
# -----------------------------------------------------------------------------
BOT_DATA_DIR=data
